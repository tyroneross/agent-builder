{
  "name": "agent-builder",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "serve": "next build && next start --port 3028",
    "build": "next build",
    "agent:scan": "node scripts/agent-scan.mjs",
    "agent:doe": "node scripts/run-agent-doe.mjs",
